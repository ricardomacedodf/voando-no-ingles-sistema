@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --font-inter: 'Inter', sans-serif;

    --background: 210 20% 98%;
    --foreground: 220 20% 10%;
    --card: 0 0% 100%;
    --card-foreground: 220 20% 10%;
    --popover: 0 0% 100%;
    --popover-foreground: 220 20% 10%;
    --primary: 148 62% 42%;
    --primary-foreground: 0 0% 100%;
    --secondary: 210 20% 96%;
    --secondary-foreground: 220 20% 20%;
    --muted: 210 15% 94%;
    --muted-foreground: 220 10% 46%;
    --accent: 210 20% 96%;
    --accent-foreground: 220 20% 10%;
    --destructive: 0 72% 51%;
    --destructive-foreground: 0 0% 100%;
    --border: 220 13% 91%;
    --input: 220 13% 91%;
    --ring: 148 62% 42%;
    --chart-1: 148 62% 42%;
    --chart-2: 24 95% 53%;
    --chart-3: 262 52% 47%;
    --chart-4: 210 100% 52%;
    --chart-5: 340 82% 52%;
    --radius: 0.75rem;

    --sidebar-background: 0 0% 100%;
    --sidebar-foreground: 220 15% 30%;
    --sidebar-primary: 148 62% 42%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 148 62% 96%;
    --sidebar-accent-foreground: 148 62% 30%;
    --sidebar-border: 220 13% 93%;
    --sidebar-ring: 148 62% 42%;

    --success: 148 62% 42%;
    --success-foreground: 0 0% 100%;
    --warning: 24 95% 53%;
    --warning-foreground: 0 0% 100%;
    --info: 210 100% 52%;
    --info-foreground: 0 0% 100%;
  }

  .dark {
    --background: 220 20% 7%;
    --foreground: 210 20% 96%;
    --card: 220 20% 10%;
    --card-foreground: 210 20% 96%;
    --popover: 220 20% 10%;
    --popover-foreground: 210 20% 96%;
    --primary: 148 62% 42%;
    --primary-foreground: 0 0% 100%;
    --secondary: 220 15% 15%;
    --secondary-foreground: 210 20% 90%;
    --muted: 220 15% 15%;
    --muted-foreground: 220 10% 55%;
    --accent: 220 15% 15%;
    --accent-foreground: 210 20% 96%;
    --destructive: 0 72% 51%;
    --destructive-foreground: 0 0% 100%;
    --border: 220 15% 18%;
    --input: 220 15% 18%;
    --ring: 148 62% 42%;
    --chart-1: 148 62% 42%;
    --chart-2: 24 95% 53%;
    --chart-3: 262 52% 47%;
    --chart-4: 210 100% 52%;
    --chart-5: 340 82% 52%;

    --sidebar-background: 220 20% 10%;
    --sidebar-foreground: 210 20% 80%;
    --sidebar-primary: 148 62% 42%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 148 62% 15%;
    --sidebar-accent-foreground: 148 62% 80%;
    --sidebar-border: 220 15% 18%;
    --sidebar-ring: 148 62% 42%;

    --success: 148 62% 42%;
    --success-foreground: 0 0% 100%;
    --warning: 24 95% 53%;
    --warning-foreground: 0 0% 100%;
    --info: 210 100% 52%;
    --info-foreground: 0 0% 100%;
  }
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground font-inter antialiased;
  }
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 6px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: hsl(var(--border));
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover {
  background: hsl(var(--muted-foreground));
}

/* Flashcard flip animation */
.flip-card {
  perspective: 1000px;
}
.flip-card-inner {
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}
.flip-card-inner.flipped {
  transform: rotateY(180deg);
}
.flip-card-front,
.flip-card-back {
  backface-visibility: hidden;
}
.flip-card-back {
  transform: rotateY(180deg);
}